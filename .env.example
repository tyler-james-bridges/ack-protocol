# ACK Protocol environment variables
# Copy to .env.local for local dev

# Required for SIWA nonce/signature verification
SIWA_NONCE_SECRET=replace-with-a-long-random-secret
RECEIPT_SECRET=replace-with-a-long-random-secret

# Required for 8004scan-backed API routes (mcp/discover/agents/reputation)
EIGHTOOSCAN_API_KEY=your-8004scan-api-key

# Public app config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
NEXT_PUBLIC_CHAIN=abstract
NEXT_PUBLIC_WC_PROJECT_ID=your-walletconnect-project-id

# Optional x402 metadata (experimental endpoint only)
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Optional agent automation credentials (scripts)
AGENT_PRIVATE_KEY=
