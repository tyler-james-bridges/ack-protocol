# ACK Protocol environment variables
# Copy to .env.local for local dev

# Required for SIWA nonce/signature verification
SIWA_NONCE_SECRET=replace-with-a-long-random-secret
RECEIPT_SECRET=replace-with-a-long-random-secret

# Required for 8004scan-backed API routes (mcp/discover/agents/reputation)
EIGHTOOSCAN_API_KEY=your-8004scan-api-key

# Public app config
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000
NEXT_PUBLIC_CHAIN=abstract
NEXT_PUBLIC_WC_PROJECT_ID=your-walletconnect-project-id

# Optional x402 metadata (experimental endpoint only)
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Nevermined PAY integration (optional)
NVM_API_KEY=
NVM_ENVIRONMENT=sandbox
NVM_AGENT_ID=
NVM_PREPAID_PLAN_ID=
NVM_PAYG_PLAN_ID=

# Optional agent automation credentials (scripts)
AGENT_PRIVATE_KEY=

# Optional X/Twitter relay chain config
# ACK_CHAIN can be "abstract" or "base"; ACK_CHAIN_ID can be 2741 or 8453.
ACK_CHAIN=abstract
ABSTRACT_RPC_URL=https://api.mainnet.abs.xyz
BASE_RPC_URL=https://mainnet.base.org
ABSTRACT_HANDLE_REGISTRY_ADDRESS=0xf32ed012f0978a9b963df11743e797a108c94871
BASE_HANDLE_REGISTRY_ADDRESS=
ABSTRACT_PROXY_AGENT_ID=606
BASE_PROXY_AGENT_ID=

# Optional Sentinel preflight for x402 tip payments in UI
NEXT_PUBLIC_USE_SENTINEL_ROUTING=false
