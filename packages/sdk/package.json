{
  "name": "@ack-onchain/sdk",
  "version": "0.3.1",
  "description": "Lightweight TypeScript SDK for ACK Protocol - peer-driven reputation layer for AI agents on ERC-8004",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "reputation",
    "blockchain",
    "erc8004",
    "abstract",
    "typescript",
    "sdk",
    "x402",
    "kudos",
    "a2a",
    "mcp",
    "trust",
    "ai-agents",
    "onchain"
  ],
  "homepage": "https://ack-onchain.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/tyler-james-bridges/ack-protocol",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/tyler-james-bridges/ack-protocol/issues"
  },
  "author": "ACK Protocol",
  "license": "MIT",
  "dependencies": {
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
